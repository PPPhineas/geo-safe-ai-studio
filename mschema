# Table: ods_gh_v1.datapointsL2, 物理场监测传感器数据
[
(DeviceSn:STRING, 设备SN),
(SensorCode:STRING, 传感器编码),
(Time:DATETIME64, 数据监测时间),
(value:NULLABLE(FLOAT32), 位移),
(OSP:NULLABLE(FLOAT64), 主要指由泥石流运动产生且在空气中传播的频率在20Hz以下的次声原始声压),
(VSP:NULLABLE(FLOAT64), 有效声压),
(freq:NULLABLE(FLOAT64), 频率),
(amplitude:NULLABLE(FLOAT64), 幅度,信号波形的最大振幅值,表明声发射事件的大小),
(energy:NULLABLE(FLOAT64), 能量,信号检波包络线下的面积,反映事件的相对能量或强度),
(ringing:NULLABLE(FLOAT64), 振铃计数,信号在一定时间内越过预置门槛的次数,反映声发射活动的总量和频度),
(risetime:NULLABLE(FLOAT64), 上升时间,信号第一次跨过门槛至最大振幅经历的时间间隔),
(risecount:NULLABLE(FLOAT64), 上升计数,信号在上升时间内越过预置门槛的次数),
(duration:NULLABLE(FLOAT64), 持续时间,信号第一次跨过门槛至最终降至门槛经历的时间间隔),
(arrivaltime:NULLABLE(FLOAT64), 到达时间,一个声发射波到达传感器的时),
(RMS:NULLABLE(FLOAT64), 有效值电压,采样时间内信号的均方根值),
(ASL:NULLABLE(FLOAT64), 平均信号电平),
(tbsj:DATETIME64, 入库时间)
]
