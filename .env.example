# 复制为 .env 并填入真实值;.env 已在 .gitignore 中忽略。
# 取代 docs/chconf.md 的明文凭据。

# ---- ClickHouse ----
CH_HOST=
CH_PORT=8123
CH_USER=
CH_PASSWORD=
CH_TABLE=dwd_gh_v1.dwd_monitor_point_info_view
# 非空时跳过 CH 查询，改为从 CSV 加载 + 空间筛选（开发/演示用）
# CH_MOCK_CSV=

# ---- LLM(低温 + JSON 模式)----
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=
LLM_TEMPERATURE=0.2

# ---- 空间分析(投影坐标系下,单位米)----
DBSCAN_EPS_M=500
DBSCAN_MIN_SAMPLES=3
PROJECTED_CRS=EPSG:4544

# ---- 重点点位 / 渲染 ----
KEY_POINTS_MAX=30
CHART_FONT_FAMILY=Microsoft YaHei
EXPORT_SCALE=2
